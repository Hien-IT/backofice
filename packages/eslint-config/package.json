{
	"name": "@backoffice/eslint-config",
	"type": "module",
	"version": "0.2.0",
	"packageManager": "pnpm@10.4.1",
	"description": "Shared ESLint config used in Directus projects",
	"author": {
		"name": "Monospace Inc",
		"email": "info@monospace.io",
		"url": "https://monospace.io"
	},
	"license": "MIT",
	"funding": "https://github.com/directus/directus?sponsor=1",
	"homepage": "https://directus.io",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/directus/eslint-config.git"
	},
	"exports": {
		".": "./dist/index.js",
		"./package.json": "./package.json"
	},
	"files": [
		"dist"
	],
	"engines": {
		"node": ">=22",
		"pnpm": "10"
	},
	"maintainers": [
		{
			"name": "Pascal Jufer",
			
			"url": "https://github.com/paescuj"
		}
	],
	"scripts": {
		"build": "pnpm run '/^(bundle|typecheck)$/'",
		"bundle": "tsup",
		"typecheck": "tsc --noEmit",
		"fetch-dprint-plugins": "node scripts/fetch-dprint-plugins.js",
		"lint": "eslint",
		"test": "vitest --watch=false",
		"inspect": "pnpm exec eslint-config-inspector"
	},
	"peerDependencies": {
		"eslint": "^10.0.0"
	},
	"dependencies": {
		"@dprint/formatter": "0.5.1",
		"@eslint-community/eslint-plugin-eslint-comments": "4.7.1",
		"@eslint/js": "10.0.1",
		"@eslint/markdown": "8.0.1",
		"@stylistic/eslint-plugin": "5.10.0",
		"@typescript-eslint/eslint-plugin": "8.59.3",
		"@typescript-eslint/parser": "8.59.3",
		"@vitest/eslint-plugin": "1.6.17",
		"eslint-config-flat-gitignore": "2.3.0",
		"eslint-flat-config-utils": "3.2.0",
		"eslint-formatting-reporter": "0.0.0",
		"eslint-merge-processors": "2.0.0",
		"eslint-parser-plain": "0.1.1",
		"eslint-plugin-antfu": "3.2.3",
		"eslint-plugin-command": "3.5.2",
		"eslint-plugin-import-x": "4.16.2",
		"eslint-plugin-jsdoc": "62.9.0",
		"eslint-plugin-jsonc": "3.1.2",
		"eslint-plugin-n": "18.0.1",
		"eslint-plugin-perfectionist": "5.9.0",
		"eslint-plugin-regexp": "3.1.0",
		"eslint-plugin-toml": "1.3.1",
		"eslint-plugin-unicorn": "64.0.0",
		"eslint-plugin-unused-imports": "4.4.1",
		"eslint-plugin-vue": "10.9.1",
		"eslint-plugin-yml": "3.3.2",
		"eslint-processor-vue-blocks": "2.0.0",
		"globals": "17.6.0",
		"jsonc-eslint-parser": "3.1.0",
		"synckit": "0.11.12",
		"toml-eslint-parser": "1.0.3",
		"vue-eslint-parser": "10.4.0",
		"yaml-eslint-parser": "2.0.0"
	},
	"devDependencies": {
		"@backoffice/tsconfig": "workspace:*",
		"@eslint/config-inspector": "3.0.2",
		"@types/node": "25.7.0",
		"eslint": "10.3.0",
		"execa": "9.6.1",
		"jiti": "2.7.0",
		"tsup": "8.5.1",
		"tsx": "4.21.0",
		"typescript": "6.0.3",
		"unplugin-replace": "0.9.0",
		"vitest": "4.1.6"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		]
	}
}
